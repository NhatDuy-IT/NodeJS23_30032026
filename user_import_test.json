{
  "info": {
    "name": "User Import + Mailtrap Test",
    "_postman_id": "user-import-test",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Login Admin (lấy token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.collectionVariables.set(\"admin_token\", pm.response.json());"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\"username\":\"admin\",\"password\":\"admin123\"}"
        },
        "url": "localhost:3000/auth/login"
      }
    },
    {
      "name": "2. Import Users từ file (3 users test)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Users imported', () => {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().created).to.eql(3);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{admin_token}}"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"users\": [\n    {\"username\": \"nhatduy01\", \"email\": \"nhatduy01@test.com\"},\n    {\"username\": \"user02\", \"email\": \"user02@test.com\"},\n    {\"username\": \"user03\", \"email\": \"user03@test.com\"}\n  ]\n}"
        },
        "url": "localhost:3000/users/import"
      }
    },
    {
      "name": "3. Verify Mailtrap",
      "request": {
        "method": "GET",
        "url": {
          "raw": "https://mailtrap.io",
          "protocol": "https",
          "host": ["mailtrap.io"]
        },
        "description": "Check 3 emails password random 16 ký tự!"
      }
    }
  ]
}
